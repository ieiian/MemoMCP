# ============================================================
# .dockerignore — Docker 构建时忽略的文件
# 只将运行时需要的文件拷入镜像
# ============================================================

# Python 缓存与编译产物
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg

# 虚拟环境
venv/
.venv/
env/

# 环境变量（含敏感信息，绝不能进镜像）
.env
.env.*
!.env.example

# 测试文件（生产镜像不需要）
tests/
.pytest_cache/
.coverage
htmlcov/

# 代码检查缓存
.mypy_cache/
.ruff_cache/
.bandit/

# Git
.git/
.gitignore
.gitattributes
.github/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 文档与脚本（镜像内不需要）
*.md
*.sh
mcp-config.example.json
ARCHITECTURE.md
README.md

# 系统文件
.DS_Store
Thumbs.db

# Docker 自身文件
Dockerfile
.dockerignore
docker-compose.yml

# 日志
*.log
logs/
